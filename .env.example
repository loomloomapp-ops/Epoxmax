# CRM webhook endpoint. Replace with your CRM integration URL.
# Example: HubSpot Forms API, Pipedrive webhook, Bitrix24 webhook, custom proxy.
# Leave empty in dev: the server will log payloads to console instead of POSTing.
CRM_ENDPOINT=

# Optional shared secret sent in the X-Lead-Token header. Validate it on the CRM side.
CRM_TOKEN=

# Public site origin used for SEO metadata, sitemap and Open Graph URLs.
NEXT_PUBLIC_SITE_URL=https://panele-dekoracyjne.pl

# Optional analytics ids. Leave empty to disable.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=

# Public contact data shown in the footer and floating widget.
NEXT_PUBLIC_CONTACT_PHONE=+48 600 000 000
NEXT_PUBLIC_CONTACT_EMAIL=kontakt@panele-dekoracyjne.pl
